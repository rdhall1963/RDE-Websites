{
    "name": "rde-wordpress-platform",
    "description": "WordPress platform with WooCommerce and Elementor",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.0",
        "composer/installers": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "lint": "phpcs --standard=WordPress themes/ plugins/",
        "lint:fix": "phpcbf --standard=WordPress themes/ plugins/",
        "test": "phpunit",
        "analyze": "phpstan analyze themes/ plugins/ --level=5"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
