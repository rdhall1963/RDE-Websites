{
  "name": "rde-wordpress-platform",
  "version": "1.0.0",
  "description": "WordPress/WooCommerce platform with Elementor customization",
  "main": "index.php",
  "scripts": {
    "dev": "wp-env start",
    "build": "npm run build:theme && npm run build:plugins",
    "build:theme": "cd themes/custom-theme && npm run build",
    "build:plugins": "cd plugins/custom-plugins && npm run build",
    "lint": "npm run lint:php && npm run lint:js",
    "lint:php": "composer run lint",
    "lint:js": "eslint themes/ plugins/ --ext .js",
    "test": "npm run test:php && npm run test:js",
    "test:php": "composer run test",
    "test:js": "jest"
  },
  "keywords": [
    "wordpress",
    "woocommerce",
    "elementor",
    "multilingual",
    "seo"
  ],
  "author": "RDE Websites",
  "license": "GPL-3.0",
  "devDependencies": {
    "@wordpress/env": "^8.0.0",
    "@wordpress/scripts": "^26.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.0.0"
  },
  "dependencies": {}
}
