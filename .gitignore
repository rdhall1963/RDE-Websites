# Global .gitignore for RDE-Websites project

# WordPress
wordpress/
wp-config.php
.htaccess
wp-content/uploads/
wp-content/cache/
wp-content/backups/
*.sql
*.sql.gz

# Node modules
node_modules/
package-lock.json
yarn.lock

# Composer
vendor/
composer.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
*.egg-info/
dist/
build/

# Environment variables
.env
.env.local
.env.*.local
*.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build files
dist/
build/
*.min.js
*.min.css

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# OS
Thumbs.db
.DS_Store
.directory

# Security
*.key
*.pem
*.crt
secrets.json

# Archives
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Media
# Uncomment if you want to ignore media files
# *.jpg
# *.jpeg
# *.png
# *.gif
# *.mp4
# *.mov

# Testing
coverage/
.nyc_output/
.phpunit.result.cache

# Documentation builds
docs/_build/
site/
